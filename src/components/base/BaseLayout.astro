---
import Footer from "@components/base/Footer.astro";
import Header from "@components/base/Header.astro";
import ObserverScript from "@components/base/ObserverScript.astro";
import SeoHead from "@components/common/SeoHead.astro";
import "@/styles/main.scss";
import { ClientRouter } from "astro:transitions";
import Background from "@/components/base/Background.astro";
import { Tooltips } from "astro-tooltips";

// types for frontmatters
export interface Props {
  title?: string;
  description?: string | null;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  ogType?: 'website' | 'article' | 'profile';
  author?: string;
  publishedAt?: string;
  updatedAt?: string;
  jsonLd?: Record<string, unknown>[] | Record<string, unknown>;
}

const {
  title,
  description,
  image,
  noindex,
  canonical,
  ogType,
  author,
  publishedAt,
  updatedAt,
  jsonLd,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- favicon -->
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicon/apple-touch-icon.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicon/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicon/favicon-16x16.png"
    />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,600;1,9..144,700&display=swap"
      rel="stylesheet"
    />
    
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta name="google-site-verification" content="r7tnL5p-9Q4RBi3fOipiKPg6vvZLg14CW8KIZJx2baw" />

    <meta name="theme-name" content="pages" />
    <meta name="msapplication-TileColor" content="#000000" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#fff"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#000"
    />
    <meta name="generator" content={Astro.generator} />

    <SeoHead
      title={title}
      description={description ? description : undefined}
      ogImage={image}
      ogType={ogType}
      canonicalUrl={canonical}
      noIndex={noindex}
      author={author}
      publishedAt={publishedAt}
      updatedAt={updatedAt}
      jsonLd={jsonLd}
    />

    <!-- https://docs.astro.build/en/guides/view-transitions -->
    <ClientRouter fallback="swap" />
    <Tooltips interactive={false} delay={[333, 0]} />
  </head>
  <body>
    <Background />
    <Header />
    <main id="main-content" class="flex-1">
      <slot/>
    </main>
    <Footer />
    <!-- <ObserverScript /> -->
  </body>
</html>
