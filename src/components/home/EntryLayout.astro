---
import BaseLayout from "@components/base/BaseLayout.astro";
import { markdownify } from "@lib/textConverter";
import Button from "@components/common/Button.astro";
import type { HomeEntry } from "@/types";
import { Image } from "astro:assets";
import { buildWebSiteSchema, buildOrganizationSchema, buildBreadcrumbSchema } from "@lib/schema";

interface Props {
  entry: HomeEntry;
}

const { entry } = Astro.props;
const { image, imageAlt, title, content, button } = entry.data;

// Convert markdown content to HTML for rich rendering
const htmlContent = content ? markdownify(content, true) : "";

const websiteSchema = buildWebSiteSchema();
const organizationSchema = buildOrganizationSchema();
const breadcrumbSchema = buildBreadcrumbSchema([{ label: "Home", href: "/" }]);
const jsonLd = [organizationSchema, websiteSchema, breadcrumbSchema];
---

<BaseLayout jsonLd={jsonLd}>
  <!-- Banner -->
  <section class="section">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-10">
          {
            image && (
              <div class="blur-[0px]">
                <Image
                class="mb-6 w-64 mx-auto"
                src={image}
                alt={imageAlt}
                width={1024}
                height={1024}
                loading="eager"
              />
              </div>
            )
          }
          <h1 set:html={markdownify(title)} class="mb-6 text-center" />
          <div set:html={htmlContent} class="content mx-auto lg:col-10" />
          {
            button && (
              <div class="mt-8 text-center">
                <Button
                  label={button.label}
                  link={button.link}
                  newtab
                  hoverInvert
                  color=""
                />
              </div>
            )
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
