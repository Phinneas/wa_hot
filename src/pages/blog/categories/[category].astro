---
export const prerender = false;
import { getWollyBlogEntries } from "@lib/wolly";
import taxonomyFilter from "@lib/taxonomyFilter";
import TaxonLayout from "@components/blog/TaxonLayout.astro";

const { category } = Astro.params;
if (!category) return Astro.redirect("/blog");

const entries = await getWollyBlogEntries();
const filteredEntries = taxonomyFilter(entries, "categories", category);
---

<TaxonLayout taxon={category} entries={filteredEntries} />
